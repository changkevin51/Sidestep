# Copy this file to /home/qnx/v2v-alert.env on BOTH Pis, replace every quoted
# value, then run: chmod 600 /home/qnx/v2v-alert.env
# Do NOT commit your edited copy and do NOT place these values in config.json.

# Paste the API key from https://elevenlabs.io/app/settings/api-keys.
export ELEVENLABS_API_KEY='PASTE_YOUR_ELEVENLABS_API_KEY_HERE'

# Paste the voice ID exactly as supplied by ElevenLabs (not the voice name).
export ELEVENLABS_VOICE_ID='PASTE_YOUR_ELEVENLABS_VOICE_ID_HERE'

# Paste your model ID exactly. eleven_flash_v2_5 is the low-latency default.
export ELEVENLABS_MODEL_ID='PASTE_YOUR_ELEVENLABS_MODEL_ID_HERE'

# Replace with the IPv4 address shown for the laptop's hotspot/Wi-Fi adapter.
# Keep :8000 unless you changed V2V_HTTP_PORT on the laptop.
export V2V_ALERT_BRIDGE_URL='http://LAPTOP_IPV4_ADDRESS:8000'

# Paste the same random value generated in the laptop PowerShell window.
export V2V_ALERT_TOKEN='PASTE_THE_LAPTOP_V2V_ALERT_TOKEN_HERE'
